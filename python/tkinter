import tkinter as tk

ventana = tk.Tk()
ventana.title("Conversor de Temperatura")
ventana.geometry("300x200")

titulo = tk.Label(ventana,text="Conversor Celsius a Fahrenheit")

def convertir():
    celsius = float(entrada.get())
    fahrenheit = (celsius * 9/5) + 32
    resultado.config(text=f"{fahrenheit} °F")

titulo.pack(pady=10)
entrada = tk.Entry(ventana)
entrada.pack()
boton = tk.Button(ventana, 
                  text="Convertir",
                  command=convertir)

boton.pack(pady=10)
resultado = tk.Label(ventana, 
                     text="")
resultado.pack()

ventana.mainloop()
