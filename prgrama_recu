from herramientas_apoyo import simplificar_fraccion
def sumar_fracciones(num1,den1,num2,den2):
    numerador = (num1*den2) + (num2*den1)
    denominador = den1*den2
    return simplificar_fraccion(numerador,denominador)

def restar_fracciones(num1,den1,num2,den2):
    numerador = (num1*den2) - (num2*den1)
    denominador = den1*den2
    return simplificar_fraccion(numerador,denominador)

def multiplicar_fracciones(num1,den1,num2,den2):
    numerador = num1*num2
    denominador = den1*den2
    return simplificar_fraccion(numerador,denominador)

def dividir_fracciones(num1,den1,num2,den2):
    numerador = num1*den2
    denominador = den1*num2
    return simplificar_fraccion(numerador,denominador)

def potencia_fraccion(numerador,denominador,exponente):
    if exponente < 0:
        variable_usuario = numerador
        numerador = denominador
        denominador = variable_usuario
        exponente = -exponente
    numerador = numerador**exponente
    denominador = denominador**exponente
    return simplificar_fraccion(numerador,denominador)




